// Wrapper resource file for scrcpyw.exe (SCRCPYW build).
// Generated by configure_file() from scrcpyw-wrapper.rc.in.
//
// This is a full copy of scrcpy-windows.rc with all relative paths rewritten
// to absolute via @SRCDIR@, so windres can find data/icon.ico and the
// embedded RCDATA binaries regardless of where the wrapper lands in the
// build tree. compile_resources() sees a distinct source file name
// (scrcpyw-wrapper.rc) and does not collide with the scrcpy.exe target.
#include <winuser.h>

0 ICON "@SRCDIR@/data/icon.ico"
1 RT_MANIFEST "@SRCDIR@/scrcpy-windows.manifest"
2 VERSIONINFO
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904E4"
    BEGIN
      VALUE "FileDescription", "Display and control your Android device"
      VALUE "InternalName", "scrcpy"
      VALUE "LegalCopyright", "Romain Vimont, Genymobile"
      VALUE "OriginalFilename", "scrcpy.exe"
      VALUE "ProductName", "scrcpy"
      VALUE "ProductVersion", "4.0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x409, 1252
  END
END

#ifdef SCRCPYW
101 RCDATA "@SRCDIR@/data/adb.exe"
102 RCDATA "@SRCDIR@/data/AdbWinApi.dll"
103 RCDATA "@SRCDIR@/data/AdbWinUsbApi.dll"
104 RCDATA "@SRCDIR@/data/scrcpy-server"
#endif
